---
import '../styles/sections/hero.css';
---

<section class="hero">
  <div class="container hero-container">
    <div class="hero-content">
      <div class="badge-new">NUEVA ERA DIGITAL 2026</div>
      <h1 class="hero-title">Construimos el <span class="text-gradient">Futuro</span> del Código</h1>
      <p class="hero-subtitle">Ingeniería de software de alto rendimiento y soluciones de infraestructura crítica para empresas que demandan excelencia y escalabilidad absoluta.</p>
      <div class="hero-btns">
        <a href="#contact" class="btn btn-primary btn-lg">
          <span>Iniciar Proyecto</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
        </a>
        <a href="#portfolio" class="btn btn-outline btn-lg">
          <span>Explorar Ecosistema</span>
        </a>
      </div>
    </div>
    <div class="hero-visual">
      <div class="code-window">
        <div class="window-header">
          <div class="dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <div class="window-title">lumaxcorp.sys</div>
        </div>
        <div class="window-body">
          <div class="code-line"><span class="c-1">import</span> &#123; LumaX <span class="c-1">from</span> <span class="c-2">'@lumax/core'</span>;</div>
          <div class="code-line"></div>
          <div class="code-line"><span class="c-1">const</span> app = <span class="c-1">new</span> <span class="c-3">LumaX</span>(&#123;</div>
          <div class="code-line">&nbsp;&nbsp;vision: <span class="c-2">'limitless'</span>,</div>
          <div class="code-line">&nbsp;&nbsp;performance: <span class="c-2">'max'</span>,</div>
          <div class="code-line">&nbsp;&nbsp;security: <span class="c-1">true</span></div>
          <div class="code-line">&#125;);</div>
          <div class="code-line"></div>
          <div class="code-line">app.<span class="c-3">deploy</span>().<span class="c-3">then</span>(() => &#123;</div>
          <div class="code-line">&nbsp;&nbsp;<span class="c-4">console</span>.<span class="c-3">log</span>(<span class="c-2">'Future is Online 🚀'</span>);</div>
          <div class="code-line">&#125;);</div>
          <div class="cursor"></div>
        </div>
      </div>
      <div class="visual-glow"></div>
    </div>
  </div>
</section>
