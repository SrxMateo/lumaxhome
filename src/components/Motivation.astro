---
import '../styles/sections/motivation.css';

const quotes = [
  {
    text: "La mejor forma de predecir el futuro es creándolo.",
    author: "LumaX Philosophy"
  },
  {
    text: "La excelencia no es un acto, es un hábito.",
    author: "Aristóteles"
  },
  {
    text: "El código es poesía escrita para máquinas que cambia el mundo.",
    author: "LumaX Engineering"
  }
];
---

<section class="motivation">
  <div class="container">
    <div class="quotes-grid">
      {quotes.map((quote) => (
        <div class="quote-card">
          <div class="quote-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 2.5 1 4.5 4 6"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 2.5 1 4.5 4 6"/></svg>
          </div>
          <p class="quote-text">"{quote.text}"</p>
          <span class="quote-author">— {quote.author}</span>
        </div>
      ))}
    </div>
  </div>
</section>
